{
  "name": "@lordfokas/magic-orm",
  "type": "module",
  "version": "5.0.0-alpha.0",
  "author": "LordFokas",
  "license": "MIT",
  "description": "A class-based ORM in TypeScript. Unorthodox and extremely opinionated, made to fit my specific use cases.",
  "repository": "https://github.com/LordFokas/magic-orm",
  "main": "dist/index.js",
  "keywords": [
    "node",
    "nodejs",
    "typescript",
    "orm",
    "postgres",
    "postgresql",
    "pg"
  ],
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "build": "tsc -p ./tsconfig.json",
    "prebuild-bin": "rm -rf ./bin",
    "build-bin": "tsc -p ./tsconfig-bin.json",
    "prepublishOnly": "npm run build && npm run build-bin",
    "cli": "node ./bin/magic-orm.js"
  },
  "bin": {
    "magic-orm": "bin/magic-orm.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/pg-pool": "^2.0.6",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^9.0.7",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@lordfokas/loggamus": "^2.0.1",
    "commander": "^11.1.0",
    "pg": "^8.11.3",
    "semver": "^7.8.5",
    "uuid": "^14.0.1"
  }
}
